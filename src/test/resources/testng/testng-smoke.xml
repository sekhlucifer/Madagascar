<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Smoke Suite" verbose="1" parallel="methods" thread-count="2">

    <parameter name="browser" value="chrome"/>
    <parameter name="env"     value="qa"/>

    <listeners>
        <listener class-name="com.framework.listeners.TestListener"/>
        <listener class-name="com.framework.listeners.RetryTransformer"/>
    </listeners>

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.framework.tests.sample"/>
        </packages>
    </test>

</suite>
