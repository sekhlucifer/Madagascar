<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Master TestNG suite.
  Run:   ./gradlew test -Denv=qa -Dbrowser=chrome
  Smoke: ./gradlew test -Denv=qa -Dgroups=smoke
-->
<suite name="Automation Suite" verbose="1" parallel="methods" thread-count="4">

    <!-- ── Global Parameters ─────────────────────────────────────────── -->
    <parameter name="browser" value="chrome"/>
    <parameter name="env"     value="qa"/>

    <!-- ── Listeners ─────────────────────────────────────────────────── -->
    <listeners>
        <listener class-name="com.framework.listeners.TestListener"/>
<!--        <listener class-name="com.framework.listeners.RetryTransformer"/>-->
    </listeners>

    <!-- ── Test Groups ───────────────────────────────────────────────── -->

<!--    <test name="Smoke Tests" preserve-order="true">-->
<!--        <groups>-->
<!--            <run>-->
<!--                <include name="smoke"/>-->
<!--            </run>-->
<!--        </groups>-->
<!--        <packages>-->
<!--            <package name="com.framework.tests.sample"/>-->
<!--        </packages>-->
<!--    </test>-->

    <test name="Regression Tests" preserve-order="true">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="com.framework.tests.sample"/>
        </packages>
    </test>

    <test name="Patient Lookup Tests" preserve-order="true">
        <classes>
           
            <class name="com.framework.tests.TOI_UM_WorkFlow"/>
            <class name="com.framework.tests.SessionSetupTests"/>
        </classes>
    </test>


<!--    <test name="All Tests" preserve-order="true">-->
<!--        <packages>-->
<!--            <package name="com.framework.tests.sample"/>-->
<!--        </packages>-->
<!--    </test>-->

</suite>
